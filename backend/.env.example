# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# PostgreSQL
DATABASE_URL=postgres://shopcore:shopcore@localhost:5432/shopcore

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=super-access-secret-change-me
JWT_REFRESH_SECRET=super-refresh-secret-change-me
JWT_ACCESS_TTL=900          # 15 хвилин (у секундах)
JWT_REFRESH_TTL=1209600     # 14 днів (у секундах)

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# --- Нова Пошта ---
# Без ключа працює локальний довідник міст/відділень (демо-режим).
NP_API_KEY=
NP_SENDER_CITY_REF=

# --- Платіжний шлюз ---
# mock — вбудований демо-шлюз. Секрет використовується для підпису вебхуків (HMAC-SHA256).
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret
PAYMENT_RETURN_URL=http://localhost:5173/orders

# --- Телефонія (CRM) ---
# mock — вбудований емулятор АТС (сам «піднімає слухавку» через 2.5 с).
# Для реальної АТС (Asterisk / Binotel / Zadarma) достатньо змінити провайдера:
# вебхук POST /api/telephony/webhook уже приймає answered/completed/no_answer/busy/failed.
TELEPHONY_PROVIDER=mock
TELEPHONY_WEBHOOK_SECRET=dev-telephony-secret
TELEPHONY_MOCK_ANSWER_MS=2500
